//1. Binary Search 
 
#include <stdio.h> 
 
int main() { 
    // Variables for size (n), search target (key), and array (a) 
    // l = left pointer, r = right pointer, m = middle pointer 
    int n, key, l = 0, r, m, a[100]; 
 
    // --- 1. Get User Input --- 
    printf("Enter number of elements: "); 
    scanf("%d", &n); 
     
    // Binary search requires a SORTED array to work properly 
    printf("Enter %d sorted numbers: ", n); 
    for(int i = 0; i < n; i++) { 
        scanf("%d", &a[i]); 
    } 
 
    printf("Enter number to search: "); 
    scanf("%d", &key); 
 
    // --- 2. Binary Search Algorithm --- 
    r = n - 1; // Set right pointer to the last index of the array 
 
    // Loop until the search space is exhausted 
    while (l <= r) { 
        // Calculate middle index (avoids integer overflow for large arrays) 
        m = l + (r - l) / 2;  
 
        // Condition A: We found the key at the middle! 
        if (a[m] == key) { 
            printf("Found at index %d\n", m); 
            return 0; // Exit the program successfully 
        } 
         
        // Condition B: Key is larger than the middle element 
        // Discard the left half by moving the left pointer past mid 
        if (a[m] < key) { 
            l = m + 1; 
        }  
        // Condition C: Key is smaller than the middle element 
        // Discard the right half by moving the right pointer before mid 
        else { 
            r = m - 1; 
        } 
    } 
 
    // --- 3. Not Found --- 
    // If the loop finishes without returning, the element isn't in the array 
    printf("Not found\n"); 
     
    return 0; 
} 
 
