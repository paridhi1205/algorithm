
 
#include <stdio.h> 
 
// Merges two subarrays of arr[]. 
// First subarray is arr[l..m], Second subarray is arr[m+1..r] 
void merge(int arr[], int l, int m, int r) { 
    int n1 = m - l + 1, n2 = r - m; 
    int L[n1], R[n2]; // Using C99 Variable Length Arrays for simplicity 
 
    // Copy data to temp arrays L[] and R[] 
    for (int i = 0; i < n1; i++) L[i] = arr[l + i]; 
    for (int j = 0; j < n2; j++) R[j] = arr[m + 1 + j]; 
 
    // Merge the temp arrays back into arr[l..r] 
    int i = 0, j = 0, k = l; 
    while (i < n1 && j < n2)  
        arr[k++] = (L[i] <= R[j]) ? L[i++] : R[j++]; 
 
    // Copy the remaining elements of L[], if any 
    while (i < n1) arr[k++] = L[i++]; 
     
    // Copy the remaining elements of R[], if any 
    while (j < n2) arr[k++] = R[j++]; 
} 
 
// The main Merge Sort function 
void mergeSort(int arr[], int l, int r) { 
    if (l < r) { 
        int m = l + (r - l) / 2; // Find the midpoint 
 
        // Sort first and second halves 
        mergeSort(arr, l, m); 
        mergeSort(arr, m + 1, r); 
 
        // Merge the sorted halves 
        merge(arr, l, m, r); 
    } 
} 
 
int main() { 
    int n, arr[100]; 
 
    // --- 1. Get User Input --- 
    printf("Enter number of elements: "); 
    scanf("%d", &n); 
     
    printf("Enter %d numbers: ", n); 
    for(int i = 0; i < n; i++) { 
        scanf("%d", &arr[i]); 
    } 
 
    // --- 2. Perform Merge Sort --- 
    mergeSort(arr, 0, n - 1); 
 
    // --- 3. Print Sorted Array --- 
    printf("Sorted array: "); 
    for(int i = 0; i < n; i++) { 
        printf("%d ", arr[i]); 
    } 
    printf("\n"); 
     
    return 0; 
}
